## 6. Optimistic updates — the v5 simplified way

v5 introduces a simpler optimistic pattern via `useMutation`'s returned `variables`.
Prefer this over manual `onMutate` cache manipulation for simple cases.

```tsx
// ✅ v5 simple optimistic — use mutation variables directly in the UI
function TodoList() {
  const { data: todos = [] } = useQuery(todoQueries.all());
  const { mutate, isPending, variables } = useMutation({
    ...todoMutations.create(),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['todos'] }),
  });

  const optimisticTodo = isPending
    ? { id: 'temp', title: variables?.title, status: 'pending' }
    : null;

  return (
    <ul>
      {todos.map((t) => (
        <TodoItem key={t.id} todo={t} />
      ))}
      {optimisticTodo && <TodoItem key="optimistic" todo={optimisticTodo} dimmed />}
    </ul>
  );
}
```

```ts
// ✅ v5 manual optimistic — use for complex rollback scenarios
export function useUpdateTodo() {
  const queryClient = useQueryClient();
  return useMutation({
    ...todoMutations.update(),
    onMutate: async (updated) => {
      await queryClient.cancelQueries({ queryKey: ['todos'] });
      const previous = queryClient.getQueryData<Todo[]>(['todos']);
      queryClient.setQueryData<Todo[]>(['todos'], (old = []) =>
        old.map((t) => (t.id === updated.id ? { ...t, ...updated } : t))
      );
      return { previous };
    },
    onError: (_err, _vars, ctx) => {
      queryClient.setQueryData(['todos'], ctx?.previous);
    },
    onSettled: () => {
      queryClient.invalidateQueries({ queryKey: ['todos'] });
    },
  });
}
```


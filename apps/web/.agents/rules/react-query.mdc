## 3. `mutationOptions` — same principle for mutations

```ts
// src/mutations/users.mutations.ts
import { mutationOptions } from '@tanstack/react-query';
import { api } from '../lib/api';
import type { CreateUserDto, User } from '../types';

export const userMutations = {
  create: () =>
    mutationOptions({
      mutationFn: (dto: CreateUserDto) => api.post<User>('/users', dto),
    }),

  update: () =>
    mutationOptions({
      mutationFn: ({ id, ...dto }: Partial<User> & { id: string }) =>
        api.patch<User>(`/users/${id}`, dto),
    }),

  remove: () =>
    mutationOptions({
      mutationFn: (id: string) => api.delete(`/users/${id}`),
    }),
};
```

```tsx
// In a custom hook or component
const { mutateAsync, isPending } = useMutation({
  ...userMutations.create(),
  onSuccess: () => {
    queryClient.invalidateQueries({ queryKey: ['users'] });
  },
});
```

---

## 4. Custom hooks — when to write them

With `queryOptions` / `mutationOptions`, many simple cases **no longer need** a custom
hook. Write one only when you need to co-locate side effects, selectors, or composite logic.

```ts
// ✅ Simple — use queryOptions directly in the component
const { data } = useQuery(userQueries.detail(id));

// ✅ Worth a hook — derived state + side effect
export function useUserProfile(id: string) {
  const queryClient = useQueryClient();

  return useQuery({
    ...userQueries.detail(id),
    select: (user) => ({
      displayName: `${user.firstName} ${user.lastName}`,
      isAdmin: user.roles.includes('admin'),
    }),
  });
}

// ✅ Mutation hook — invalidation belongs together with the mutation
export function useCreateUser() {
  const queryClient = useQueryClient();
  return useMutation({
    ...userMutations.create(),
    onSuccess: (newUser) => {
      queryClient.invalidateQueries({ queryKey: ['users'] });
      queryClient.setQueryData(userQueries.detail(newUser.id).queryKey, newUser);
    },
  });
}
```


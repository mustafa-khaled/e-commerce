## 10. Invalidation strategy

```ts
// Prefer broad invalidation — let React Query decide what to refetch
queryClient.invalidateQueries({ queryKey: ['users'] })          // all user queries
queryClient.invalidateQueries({ queryKey: ['users', 'list'] })  // only lists
queryClient.invalidateQueries({ queryKey: ['users', 'detail', id] }) // one user

// After a create/update you often want to both invalidate AND seed the cache
onSuccess: (created) => {
  queryClient.invalidateQueries({ queryKey: ['users'] })
  queryClient.setQueryData(userQueries.detail(created.id).queryKey, created)
},
```

---

## 11. `select` for derived / transformed data

```ts
// ✅ Transformation runs only when source data changes; memoized automatically
export const useActiveUserNames = () =>
  useQuery({
    ...userQueries.all(),
    select: (users) =>
      users
        .filter((u) => u.status === 'active')
        .map((u) => u.name)
        .sort(),
  });
```


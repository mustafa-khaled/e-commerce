## 9. `useMutationState` — cross-component mutation awareness

```ts
// Show all pending uploads anywhere in the tree (no prop drilling)
import { useMutationState } from '@tanstack/react-query'

function UploadProgressBar() {
  const pending = useMutationState({
    filters: { mutationKey: ['upload'], status: 'pending' },
    select: (m) => m.state.variables as File,
  })

  if (!pending.length) return null
  return <div>Uploading {pending.length} file(s)…</div>
}
```


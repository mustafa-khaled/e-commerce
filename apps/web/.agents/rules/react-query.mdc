## 7. Dependent / conditional queries

```ts
// ✅ Use enabled in queryOptions or inline
export const orderQueries = {
  byUser: (userId?: string) =>
    queryOptions({
      queryKey: ['orders', userId] as const,
      queryFn: () => api.get<Order[]>(`/users/${userId}/orders`),
      enabled: !!userId,
    }),
}

// With useSuspenseQuery: don't use enabled. Compose components instead.
// ❌ useSuspenseQuery does NOT support `enabled`
// ✅ Split: render the child only when condition is met
function OrdersSection({ userId }: { userId?: string }) {
  if (!userId) return null
  return (
    <AsyncBoundary>
      <OrderList userId={userId} />
    </AsyncBoundary>
  )
}

function OrderList({ userId }: { userId: string }) {
  const { data } = useSuspenseQuery(orderQueries.byUser(userId))
  // ...
}
```


## 8. Infinite queries

```ts
// src/queries/posts.queries.ts
import { infiniteQueryOptions } from '@tanstack/react-query';

export const postQueries = {
  infinite: (search?: string) =>
    infiniteQueryOptions({
      queryKey: ['posts', 'infinite', { search }] as const,
      queryFn: ({ pageParam }) =>
        api.get<PostPage>('/posts', { params: { cursor: pageParam, search } }),
      initialPageParam: undefined as string | undefined,
      getNextPageParam: (lastPage) => lastPage.nextCursor,
      maxPages: 10, // v5: cap cached pages to avoid memory bloat
    }),
};

// In component
const { data, fetchNextPage, hasNextPage, isFetchingNextPage } = useInfiniteQuery(
  postQueries.infinite(search)
);

const posts = data?.pages.flatMap((p) => p.items) ?? [];
```

